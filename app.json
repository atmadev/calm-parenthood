{
  "expo": {
    "name": "calm-parenthood",
    "slug": "calm-parenthood",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBFBFB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oleksandr-koryttsev.calm-parenthood",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FBFBFB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.oleksandrkoryttsev.calmparenthood"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0a89b1b6-efe6-4ada-8179-e670e9df586b"
      }
    }
  }
}
